<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden" data-controller="interest-zone-dropdown">
  <div class="p-6">
    <div class="flex items-center justify-between cursor-pointer" data-action="click->interest-zone-dropdown#toggle">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full <%= empty? ? 'bg-gray-100' : 'bg-primary100' %> flex items-center justify-center">
          <svg class="w-6 h-6 <%= empty? ? 'text-gray-400' : 'text-primary600' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-bold text-gray-900"><%= label %></h3>
          <p class="text-sm text-gray-500"><%= empty? ? "Clique para configurar esta zona" : full_address %></p>
        </div>
      </div>

      <div class="flex items-center gap-2">
        <% unless empty? %>
          <div class="hidden sm:flex items-center gap-1 px-3 py-1 bg-green-50 text-green-700 rounded-full text-xs font-bold uppercase tracking-wider">
            <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
            Monitorando
          </div>
        <% end %>
        <svg class="w-5 h-5 text-gray-400 transition-transform duration-200" data-interest-zone-dropdown-target="icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </div>
    </div>

    <%# Dropdown Content %>
    <div class="hidden mt-6 pt-6 border-t border-gray-100" data-interest-zone-dropdown-target="content">
      <div class="flex flex-col gap-4">
        <% if empty? %>
          <%= render(Modal::ModalComponent.new(title: "Adicionar Zona de Interesse")) do |component| %>
            <% component.with_trigger do %>
              <div class="flex items-center justify-center gap-2 w-full py-3 px-4 bg-primary600 hover:bg-primary700 text-white font-bold rounded-xl transition-colors cursor-pointer">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                Adicionar Endereço
              </div>
            <% end %>
            <%= render 'addresses/form', address: Address.new(label: label) %>
          <% end %>
        <% else %>
          <div class="grid grid-cols-2 gap-3">
            <%= render(Modal::ModalComponent.new(title: "Editar Zona de Interesse")) do |component| %>
              <% component.with_trigger do %>
                <div class="flex items-center justify-center gap-2 py-3 px-4 bg-gray-50 hover:bg-gray-100 text-gray-700 font-bold rounded-xl transition-colors cursor-pointer">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                  </svg>
                  Editar
                </div>
              <% end %>
              <%= render 'addresses/form', address: @address %>
            <% end %>

            <%= button_to address_path(@address), method: :delete, class: "flex items-center justify-center gap-2 w-full py-3 px-4 bg-red-50 hover:bg-red-100 text-red-600 font-bold rounded-xl transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
              </svg>
              Excluir
            <% end %>
          </div>
          <%= link_to home_path(lat: @address.latitude, lng: @address.longitude), class: "flex items-center justify-center gap-2 py-3 px-4 bg-primary600 hover:bg-primary700 text-white font-bold rounded-xl transition-colors" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
            Ver no Mapa
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
