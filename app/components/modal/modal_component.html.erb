<div data-controller="modal--modal-component" class="relative">
  <div data-action="click->modal--modal-component#open">
    <%= trigger %>
  </div>

  <div data-modal--modal-component-target="modal" class="hidden fixed inset-0 overflow-y-auto flex items-center justify-center z-50">
    <div class="bg-white rounded-lg shadow-xl p-6 w-full max-w-lg mx-auto">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-semibold"><%= @title %></h2>
        <button data-action="click->modal--modal-component#close" class="text-gray-500 hover:text-gray-700">
          &times;
        </button>
      </div>
      <div>
        <%= content %>
      </div>
    </div>
  </div>
</div>
