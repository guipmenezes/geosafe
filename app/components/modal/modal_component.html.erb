<div data-controller="modal--modal-component" data-modal--modal-component-open-value="<%= @open %>" class="relative z-50">
  <div data-action="click->modal--modal-component#open">
    <%= trigger %>
  </div>

  <div data-modal--modal-component-target="modal" 
       class="<%= 'hidden' unless @open %> fixed inset-0 z-50 overflow-y-auto"
       aria-labelledby="modal-title" role="dialog" aria-modal="true">
    
    <%# Background backdrop %>
    <div data-modal--modal-component-target="backdrop"
         class="fixed inset-0 bg-gray-500 bg-opacity-75 transition-opacity" 
         data-action="click->modal--modal-component#close"></div>

    <div class="flex min-h-full items-end justify-center p-4 text-center sm:items-center sm:p-0">
      <div class="relative transform overflow-hidden rounded-lg bg-white text-left shadow-xl transition-all sm:my-8 sm:w-full sm:max-w-lg">
        <div class="bg-white px-4 pb-4 pt-5 sm:p-6 sm:pb-4">
          <div class="flex justify-between items-center mb-4">
            <h2 id="modal-title" class="text-xl font-semibold text-gray-900"><%= @title %></h2>
            <button data-action="click->modal--modal-component#close" class="text-gray-400 hover:text-gray-500 transition-colors">
              <span class="sr-only">Fechar</span>
              <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          <div>
            <%= content %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
