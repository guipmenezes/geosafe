<div id="<%= dom_id(@alert) %>" class="relative bg-white rounded-xl shadow-sm hover:shadow-md transition-shadow p-5 border-l-4 <%= case type
                                                                  when 1 then 'border-green-500'
                                                                  when 2 then 'border-yellow-500'
                                                                  when 3 then 'border-red-500'
                                                                  else 'border-grey300'
                                                                  end %>">
  <div class="flex justify-between items-start mb-3">
    <div class="flex-1">
      <div class="flex items-center gap-2">
        <span class="text-[10px] font-bold uppercase tracking-widest text-grey500 px-2 py-0.5 bg-grey100 rounded-md"><%= alert_name %></span>
        <% if can_edit? %>
          <%= link_to edit_alert_path(@alert), data: { turbo_frame: "remote_modal" }, class: "text-[10px] font-bold text-primary600 hover:text-primary700 underline" do %>
            Editar
          <% end %>
        <% end %>
      </div>
      <div class="block group cursor-pointer"
           data-action="click->alert-details#open"
           data-alert-title="<%= title %>"
           data-alert-description="<%= description %>"
           data-alert-location="<%= location %>"
           data-alert-name="<%= alert_name %>"
           data-alert-type-name="<%= alert_type_name %>"
           data-alert-type="<%= type %>"
           data-alert-creator="<%= creator_name %>"
           data-alert-date="<%= formatted_created_at %>">
        <h3 class="text-base font-semibold text-grey900 mt-2 group-hover:text-primary600 transition-colors"><%= title %></h3>
        <p class="text-xs text-grey600 mt-1 line-clamp-2"><%= description %></p>
        <div class="flex items-center gap-1 mt-2 text-[10px] text-grey500">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
          </svg>
          <%= location %>
        </div>
      </div>
    </div>
    <span class="px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider <%= case type
                                                        when 1 then 'bg-green-50 text-green-700'
                                                        when 2 then 'bg-yellow-50 text-yellow-700'
                                                        when 3 then 'bg-red-50 text-red-700'
                                                        else 'bg-grey100 text-grey700'
                                                        end %>">
      <%= alert_type_name %>
    </span>
  </div>

  <div class="flex items-center gap-6 mt-4 pt-4 border-t border-grey100 text-xs text-grey600 font-medium">
    <% user_vote = @alert.user_vote(Current.user) %>

    <%= button_to alert_votes_path(@alert, vote_type: :relevant),
                   class: "flex items-center gap-1.5 transition-colors #{user_vote&.relevant? ? 'text-primary500' : 'hover:text-primary500'}",
                   method: :post do %>
      <div class="p-1 <%= user_vote&.relevant? ? 'bg-primary50' : 'bg-grey50' %> rounded-full">
        <svg class="w-3.5 h-3.5" fill="<%= user_vote&.relevant? ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      <span class="font-bold text-grey900"><%= relevant_count %></span> <span class="hidden sm:inline">Relevante</span>
    <% end %>

    <%= button_to alert_votes_path(@alert, vote_type: :inappropriate),
                   class: "flex items-center gap-1.5 transition-colors #{user_vote&.inappropriate? ? 'text-red-500' : 'hover:text-red-500'}",
                   method: :post do %>
      <div class="p-1 <%= user_vote&.inappropriate? ? 'bg-red-50' : 'bg-grey50' %> rounded-full">
         <svg class="w-3.5 h-3.5" fill="<%= user_vote&.inappropriate? ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
         </svg>
      </div>
      <span class="font-bold text-grey900"><%= inappropriate_count %></span> <span class="hidden sm:inline">Inapropriado</span>
    <% end %>
  </div>
</div>
