<div class="min-h-screen bg-gray-50 py-12 lg:rounded-2xl shadow-sm">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <%# Header Section %>
    <div class="mb-10">
      <h1 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
        Zonas de Interesse
      </h1>
      <p class="mt-3 text-lg text-gray-500">
        Gerencie até 3 locais para monitoramento rápido e receba alertas personalizados.
      </p>
    </div>

    <%# Cards Grid %>
    <div id="interest_zones_list" class="space-y-6">
      <% 3.times do |i| %>
        <% address = @addresses[i] %>
        <%= render(InterestZoneCard::InterestZoneCardComponent.new(address: address, index: i)) %>
      <% end %>
    </div>

    <%# Info Alert %>
    <div class="mt-12 p-4 bg-blue-50 rounded-xl border border-blue-100 flex gap-4">
      <div class="flex-shrink-0">
        <svg class="h-6 w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </div>
      <div>
        <h3 class="text-sm font-bold text-blue-800 uppercase tracking-wider">Por que cadastrar Zonas?</h3>
        <p class="mt-1 text-sm text-blue-600 leading-relaxed">
          Zonas de interesse permitem que você monitore locais como sua casa, trabalho ou escola com apenas um clique. Em breve, você receberá notificações em tempo real sempre que um alerta for gerado nessas áreas.
        </p>
      </div>
    </div>
  </div>
</div>
