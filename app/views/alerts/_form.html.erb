<%= form_with(model: alert, url: alerts_path, id: "alert_form", class: "flex flex-col gap-4",
              data: { action: "turbo:submit-end->modal--modal-component#close" }) do |form| %>
  <% if alert.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 p-3 rounded mb-4">
      <h2 class="font-bold"><%= pluralize(alert.errors.count, "error") %> prohibited this alert from being saved:</h2>
      <ul>
        <% alert.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= render Select::SelectComponent.new(
        form: form,
        name: :alert_type,
        label: Alert.human_attribute_name(:alert_type),
        collection: Alert.alert_type_options,
        extra_classes: "pb-4"
      ) %>

  <%= render Select::SelectComponent.new(
        form: form,
        name: :alert,
        label: Alert.human_attribute_name(:alert),
        collection: Alert.alert_options,
        extra_classes: "pb-4"
      ) %>

  <%= render Input::InputComponent.new(
        form: form,
        name: :location,
        label: Alert.human_attribute_name(:location),
        value: alert.location,
        extra_classes: "pb-4"
      ) %>

  <div class="flex justify-center items-center">
    <%= render Button::ButtonComponent.new(text: "Criar alerta", type: "submit", extra_classes: "w-1/3 h-10 pt-5") %>
  </div>
<% end %>