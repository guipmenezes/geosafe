<%= turbo_frame_tag dom_id(alert, :form) do %>
  <%= form_with(model: alert, id: "alert_form", class: "flex flex-col gap-4",
                data: {
                  controller: "geolocation",
                  action: "turbo:submit-end->modal--modal-component#close map:location-picked@window->geolocation#handleLocationPicked"
                }) do |form| %>

    <%= form.hidden_field :latitude, data: { geolocation_target: "latitude" } %>
    <%= form.hidden_field :longitude, data: { geolocation_target: "longitude" } %>

    <% if alert.errors.any? %>
      <div id="error_explanation" class="bg-red-50 text-red-500 p-4 rounded-xl mb-4 border border-red-100">
        <h2 class="font-bold text-sm">
          <%= alert.errors.count == 1 ? "1 erro impediu este alerta de ser salvo:" : "#{alert.errors.count} erros impediram este alerta de ser salvo:" %>
        </h2>
        <ul class="text-xs mt-2 list-disc list-inside">
          <% alert.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= render Select::SelectComponent.new(
          form: form,
          name: :alert_type,
          label: Alert.human_attribute_name(:alert_type),
          collection: Alert.alert_type_options,
          extra_classes: "pb-4",
          prompt: "Selecione o nível de segurança..."
        ) %>

    <%= render Select::SelectComponent.new(
          form: form,
          name: :alert,
          label: Alert.human_attribute_name(:alert),
          collection: Alert.alert_options,
          extra_classes: "pb-4",
          html_attributes: {
            data: {
              geolocation_target: "type",
              action: "change->geolocation#handleTypeChange"
            }
          }
        ) %>

    <div class="bg-blue-50 p-3 rounded-lg text-blue-700 text-[10px] mb-2 border border-blue-100">
      <p class="font-semibold mb-1">Dica:</p>
      <p>1. Selecione se o alerta é residencial ou na rua.</p>
      <p>2. Clique no mapa para marcar o local exato (para alertas na rua).</p>
      <p>3. Não esqueça de definir o nível de segurança (Seguro, Atenção ou Perigo).</p>
    </div>

    <%= render Input::InputComponent.new(
          form: form,
          name: :title,
          label: Alert.human_attribute_name(:title),
          extra_classes: "pb-4"
        ) %>

    <%= render TextArea::TextAreaComponent.new(
          form: form,
          name: :description,
          label: Alert.human_attribute_name(:description),
          extra_classes: "pb-4"
        ) %>

    <%= render Input::InputComponent.new(
          form: form,
          name: :location,
          label: Alert.human_attribute_name(:location),
          value: alert.location,
          extra_classes: "pb-4",
          html_attributes: {
            data: { geolocation_target: "location" }
          }
        ) %>

    <div class="flex justify-center items-center mt-6">
      <%= render Button::ButtonComponent.new(text: alert.new_record? ? "Criar alerta" : "Atualizar alerta", type: "submit", extra_classes: "w-1/2") %>
    </div>
  <% end %>
<% end %>
