<%= form_with(model: alert, url: alerts_path) do |form| %>
  <% if alert.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(alert.errors.count, "error") %> prohibited this alert from being saved:</h2>
      <ul>
        <% alert.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex flex-col gap-2 pb-4">
    <%= form.label :alert %>
    <%= form.number_field :alert %>
  </div>

  <div class="flex flex-col gap-2 pb-4">
    <%= form.label :location %>
    <%= form.text_field :location %>
  </div>

  <div class="flex flex-col gap-2 pb-4">
    <%= form.label :resident %>
    <%= form.check_box :resident %>
  </div>

  <div class="flex justify-center items-center">
    <%= form.submit "Create Alert", class: "w-1/3 h-10 pt-5" %>
  </div>
<% end %>
