<%= turbo_stream.prepend "alerts", render(AlertCard::AlertCardComponent.new(alert: @alert)) %>

<%= turbo_stream.replace "new_alert_form", partial: "alerts/form", locals: { alert: Alert.new } %>

<script data-turbo-cache="false">
  (function() {
    const alertData = <%= {
      id: @alert.id,
      latitude: @alert.latitude,
      longitude: @alert.longitude,
      title: @alert.title,
      alert_type: @alert.alert_type
    }.to_json.html_safe %>;
    
    if (alertData.latitude && alertData.longitude) {
      window.dispatchEvent(new CustomEvent("alert:created", {
        detail: { alert: alertData }
      }));
    }
  })();
</script>
