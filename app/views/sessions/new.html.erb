<div class="grid grid-cols-1 lg:grid-cols-2 w-full min-h-screen">
  <div class="hidden lg:block h-full relative">
    <%= image_tag "daniel-costa-jKRd3AjAnZI-unsplash.jpg", alt: "Imagem de uma pessoa escalando uma montanha com um céu azul e com nuvens ao fundo. Foto tirada pelo fotógrafo Wia Spale.", class: "w-full h-full object-cover" %>
    <a href="https://unsplash.com/pt-br/@danielpcosta"><p class="absolute bottom-4 left-4 text-white bg-black bg-opacity-50 px-2 py-1 rounded">Foto por Daniel Costa</p></a>
  </div>
  <div class="flex flex-col justify-center items-center bg-white px-4">
    <div class="flex flex-col items-start gap-6 sm:gap-8 py-8 w-full max-w-md lg:max-w-xl mx-auto">
      <h1 class="font-semibold text-xl sm:text-2xl text-gray-900">Para entrar no GeoSafe, insira o seu e-mail e senha.</h1>
      <div class="w-full">
        <%= form_with(url: sign_in_path) do |form| %>
          <div class="flex flex-col gap-2 pb-4">
            <%= render(Input::InputComponent.new(name: :email, form: form, value: params[:email_hint], required: true, autofocus: true, autocomplete: "email", label: "Email:", placeholder: "Insira aqui o seu principal e-mail.")) %>
          </div>

          <div class="flex flex-col gap-2 pb-4">
            <%= render(Input::InputComponent.new(name: :password, form: form, required: true, autocomplete: "current-password", label: "Senha:", placeholder: "Insira a sua senha.", password: true)) %>
          </div>

          <div class="flex justify-center items-center mt-6">
            <%= render(Button::ButtonComponent.new(text: "ENTRAR", type: "submit", extra_classes: "w-full sm:w-2/3 md:w-1/2")) %>
          </div>
          <div class="flex flex-col justify-center items-center gap-2 w-full pt-8">
            <%= link_to "Não possui uma conta? Cadastre-se", sign_up_path, class: "text-gray-600 hover:text-blue-700" %>
            <%= link_to "Esqueceu a sua senha?", new_identity_password_reset_path, class: "text-gray-600 hover:text-blue-700" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
