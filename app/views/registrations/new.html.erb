<div class="grid grid-cols-1 lg:grid-cols-2 w-full min-h-screen" data-controller="registrations--form">
  <div class="hidden lg:block h-full relative">
    <%= image_tag "daniel-costa-wz5XO9Lo3E8-unsplash.jpg", alt: "Imagem do Catedral Metropolitana Nossa Senhora Aparecida, em Brasília. Foto tirada pelo fotógrafo Daniel Costa.", class: "w-full h-full object-cover" %>
    <a href="https://unsplash.com/pt-br/@danielpcosta"><p class="absolute bottom-4 left-4 text-white bg-black bg-opacity-50 px-2 py-1 rounded">Foto por Daniel Costa</p></a>
  </div>
  <div class="flex flex-col justify-center items-center bg-white px-4">
    <div class="flex flex-col items-start gap-6 sm:gap-8 py-8 w-full max-w-md lg:max-w-xl mx-auto">
      <h1 class="font-semibold text-xl sm:text-2xl text-gray-900">Seja bem-vindo(a), para começar nós precisamos que você preencha os seguintes campos</h1>
      <div class="w-full">
        <%= form_with(model: @user, url: sign_up_path) do |form| %>
          <div class="flex flex-col gap-2 pb-4">
            <%= render(Input::InputComponent.new(name: :full_name, form: form, value: @user.full_name, label: "Nome completo:", required: true, autofocus: true, autocomplete: "fullname", placeholder: "Digite o seu nome completo aqui.")) %>
          </div>

          <div class="flex flex-col gap-2 pb-4">
            <%= render(Input::InputComponent.new(name: :username, form: form, value: @user.username, required: true, autofocus: true, autocomplete: "username", label: "Nome de usuário:", placeholder: "Crie o seu nome de usuário.")) %>
          </div>

          <div class="flex flex-col gap-2 pb-4">
            <%= render(Input::InputComponent.new(name: :email, form: form, value: @user.email, required: true, autofocus: true, autocomplete: "email", label: "Email:", placeholder: "Insira aqui o seu principal e-mail.")) %>
          </div>

          <div class="flex flex-col gap-2 pb-4">
            <%= render(Input::InputComponent.new(name: :password, form: form, required: true, autofocus: true, autocomplete: "new-password", label: "Senha:", placeholder: "Crie uma nova senha.", password: true)) %>
          </div>

          <div class="flex flex-col gap-2 pb-4">
            <%= render(Input::InputComponent.new(name: :password_confirmation, form: form, required: true, autofocus: true, autocomplete: "new-password", label: "Confirme a sua senha:", placeholder: "Digite a mesma senha criada no passo anterior.", password: true)) %>
          </div>

          <div class="flex justify-center items-center mt-6">
            <%= render(Button::ButtonComponent.new(text: "AVANÇAR", type: "submit", extra_classes: "w-full sm:w-2/3 md:w-1/2")) %>
          </div>
          <div class="flex justify-center w-full pt-4">
            <%= link_to "Já possui uma conta? Entre", sign_in_path, class: "text-blue-500 hover:text-blue-700" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
