<div id="flash" class="fixed top-24 right-4 z-[200] flex flex-col gap-3 min-w-[300px]">
  <% flash.each do |type, message| %>
    <div class="rounded-xl px-6 py-4 shadow-xl border flex items-center gap-3 animate-slide-in-right
                <%= type.to_s == 'notice' ? 'bg-green-50 border-green-100 text-green-800' : 'bg-red-50 border-red-100 text-red-800' %>"
         data-controller="flash"
         data-action="click->flash#close">
      <% if type.to_s == 'notice' %>
        <svg class="w-5 h-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      <% else %>
        <svg class="w-5 h-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      <% end %>
      <span class="text-sm font-bold"><%= message %></span>
      <button class="ml-auto text-current opacity-50 hover:opacity-100">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  <% end %>
</div>
