<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <style>
      <%= File.read(Rails.root.join("app/assets/stylesheets/mailer.css")).html_safe %>
    </style>
  </head>

  <body>
    <div class="container">
      <div class="header">
        <h1>GeoSafe 🛡️</h1>
      </div>
      <div class="content">
        <%= yield %>
      </div>
      <div class="footer">
        <p>GeoSafe - Consciência situacional e segurança comunitária.</p>
        <p>Você recebeu este e-mail porque está cadastrado na nossa plataforma.</p>
      </div>
    </div>
  </body>
</html>
