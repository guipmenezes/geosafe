<%= turbo_frame_tag dom_id(address, :form) do %>
  <%= form_with(model: address, class: "space-y-6", data: { controller: "cep-search" }) do |form| %>
    <% if address.errors.any? %>
      <div class="bg-red-50 border border-red-100 rounded-2xl p-4 text-red-700 text-sm">
        <ul class="list-disc list-inside">
          <% address.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="md:col-span-2">
        <%= render(Input::InputComponent.new(
          name: :label,
          form: form,
          required: true,
          label: "Identificação (ex: Casa, Trabalho):",
          placeholder: "Ex: Casa, Trabalho, Escola"
        )) %>
      </div>

      <div class="md:col-span-2">
        <div class="flex flex-col gap-2">
          <%= render(Input::InputComponent.new(
            name: :cep,
            form: form,
            required: true,
            label: "CEP:",
            placeholder: "00000-000",
            html_attributes: {
              data: {
                action: "blur->cep-search#fetchCep"
              }
            }
          )) %>
          <p class="text-[10px] text-grey500 pl-1">Digite o CEP para preencher o endereço automaticamente.</p>
        </div>
      </div>

      <div class="md:col-span-2">
        <%= render(Input::InputComponent.new(
          name: :address,
          form: form,
          required: true,
          label: "Endereço:",
          placeholder: "Rua, Avenida, etc.",
          html_attributes: {
            data: { "cep-search-target": "logradouro" }
          }
        )) %>
      </div>

      <%= render(Input::InputComponent.new(
        name: :number,
        form: form,
        required: true,
        label: "Número:",
        placeholder: "123"
      )) %>

      <%= render(Input::InputComponent.new(
        name: :complement,
        form: form,
        label: "Complemento:",
        placeholder: "Apt, Bloco, etc."
      )) %>

      <div class="md:col-span-2">
        <%= render(Input::InputComponent.new(
          name: :state,
          form: form,
          required: true,
          label: "Bairro:",
          placeholder: "Digite o seu bairro.",
          html_attributes: {
            data: { "cep-search-target": "bairro" }
          }
        )) %>
      </div>

      <div class="md:col-span-1">
        <%= render(Input::InputComponent.new(
          name: :city,
          form: form,
          required: true,
          label: "Cidade:",
          placeholder: "Sua cidade",
          html_attributes: {
            data: { "cep-search-target": "cidade" }
          }
        )) %>
      </div>

      <div class="md:col-span-1">
        <%= render(Input::InputComponent.new(
          name: :uf,
          form: form,
          required: true,
          label: "UF:",
          placeholder: "SP",
          html_attributes: {
            data: { "cep-search-target": "estado" }
          }
        )) %>
      </div>
    </div>

    <div class="flex items-center justify-end gap-4 pt-6 border-t border-grey100">
      <%= render(Button::ButtonComponent.new(
            text: "Salvar Zona",
            type: "submit",
            size: "lg",
            extra_classes: "w-full sm:w-auto",
            html_attributes: { "data-turbo-submits-with": "Salvando..." }
          )) %>
    </div>
  <% end %>
<% end %>
