<div class="grid grid-cols-1 lg:grid-cols-2 w-full min-h-screen">
  <div class="flex flex-col justify-center items-center bg-white px-4">
    <div class="flex flex-col items-start gap-6 sm:gap-8 py-8 w-full max-w-md lg:max-w-xl mx-auto">
      <h1 class="font-semibold text-xl sm:text-2xl text-gray-900">Ótimo, agora para aprimorar a sua experiência, precisamos de informações sobre o seu endereço</h1>
      <div class="w-full">
        <%= render 'form', address: @address %>
      </div>
    </div>
  </div>
  <div class="hidden lg:block h-full relative">
    <%= image_tag "daniel-costa-wM8JvqyvYrg-unsplash.jpg", alt: "Imagem do Catedral Metropolitana Nossa Senhora Aparecida, em Brasília. Foto tirada pelo fotógrafo Daniel Costa.", class: "w-full h-full object-cover" %>
    <a href="https://unsplash.com/pt-br/@danielpcosta"><p class="absolute bottom-4 left-4 text-white bg-black bg-opacity-50 px-2 py-1 rounded">Foto por Daniel Costa</p></a>
  </div>
</div>
