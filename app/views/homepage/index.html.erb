<div class="flex flex-col min-h-screen container mx-auto mt-5 px-5">
  <!-- Barra superior com logo e informações -->
  <header class="w-full px-4 py-4 sm:px-5 md:py-6 lg:py-8 lg:px-8" data-controller="header">
    <div class="flex flex-wrap justify-between items-center w-full">
      <div class="flex items-center">
        <%= render(Logo::LogoComponent.new) %>
      </div>

      <div class="block md:hidden">
        <button class="flex items-center px-3 py-2 border rounded text-primary500 border-primary500" data-action="click->header#toggle">
          <svg class="fill-current h-3 w-3" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
            <title>Menu</title>
            <path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z" />
          </svg>
        </button>
      </div>

      <div class="w-full md:flex md:items-center md:w-auto hidden md:block" data-header-target="menu">
        <div class="flex flex-col md:flex-row md:items-center text-primary500 space-y-2 md:space-y-0 md:space-x-5 mt-4 md:mt-0">
          <%= link_to "Funcionalidades", "#funcionalidades", class: "font-semibold" %>
          <%= link_to "Por que contribuir", "#por-que-contribuir", class: "font-semibold" %>
          <%= link_to "Planos", "#planos", class: "font-semibold" %>
        </div>

        <div class="flex items-center space-x-4 mt-4 md:mt-0 md:ml-10 w-full md:w-auto">
          <%= link_to sign_in_path, class: "w-full md:w-auto" do %>
            <%= render(Button::ButtonComponent.new(text: "Entre", style: "primary", extra_classes: "w-full md:w-auto")) %>
          <% end %>
          <%= link_to sign_up_path, class: "w-full md:w-auto" do %>
            <%= render(Button::ButtonComponent.new(text: "Cadastre-se", style: "secondary", extra_classes: "w-full md:w-auto")) %>
          <% end %>
        </div>
      </div>
    </div>
  </header>

  <!-- Banner CTA com imagem e cantos arredondados -->
  <div class="relative h-[60vh] sm:h-[85vh] overflow-hidden rounded-2xl sm:rounded-[2rem] mx-2 sm:mx-4">
    <%= image_tag "mika-baumeister-nDciGidCdQo-unsplash.jpg", alt: "Imagem de homem segurando um celular com o mapa aberto.", class: "absolute inset-0 w-full h-full object-cover" %>

    <!-- Gradiente de sobreposição -->
    <div class="absolute inset-0 bg-gradient-to-r from-primary900/90 via-primary700/80 to-transparent z-10"></div>

    <!-- Conteúdo -->
    <div class="relative z-20 h-full flex items-center">
      <div class="text-white p-6 sm:p-10 max-w-xl sm:max-w-2xl">
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-semibold mb-4 sm:mb-6">
          Tenha consciência do que acontece ao seu redor
        </h1>
        <%= link_to sign_up_path do %>
          <%= render(Button::ButtonComponent.new(text: "CADASTRE-SE NA GEOSAFE", size: "lg", extra_classes: "hover:bg-primary600")) %>
        <% end %>
      </div>
    </div>

    <!-- Créditos da imagem -->
    <a href="https://unsplash.com/pt-br/@kommumikation" class="absolute bottom-2 right-4 z-30">
      <p class="text-white text-xs bg-black/50 px-2 py-1 rounded-md">
        Foto por Mika Baumeister
      </p>
    </a>
  </div>

  <!-- Conteúdo principal (agora fora da viewport inicial) -->
  <main class="bg-white">
    <div class="w-full px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto py-16 sm:py-24">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold text-gray-900 mb-6 tracking-tight">
          A inteligência coletiva a favor da <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary500 to-secondary500">sua segurança</span>
        </h2>
        <p class="text-lg sm:text-xl text-gray-600 leading-relaxed">
          O <span class="font-bold text-primary500">GeoSafe</span> é uma plataforma comunitária de consciência situacional urbana. Acreditamos que a melhor fonte de informação sobre um bairro é quem vive e transita por ele. Transformamos o mapa da cidade em um organismo vivo, onde a colaboração direta gera segurança para todos.
        </p>
      </div>
    </div>

    <div class="bg-gray-50 rounded-2xl sm:rounded-[2rem] mx-2 sm:mx-4 mb-12 sm:mb-16 border border-gray-100 shadow-sm overflow-hidden">
      <%= render "homepage/partials/features" %>
    </div>
  </main>

  <footer class="flex flex-col text-center bg-gray-50 rounded-2xl sm:rounded-[2rem] mx-2 sm:mx-4 mb-6 sm:mb-8 border border-gray-100 shadow-sm justify-center items-center p-6 sm:p-8 gap-4">
    <div class="flex flex-row">
      <%= render(Logo::LogoComponent.new) %>
    </div>
    <span class="text-primary900 text-sm font-medium">Criado e mantido por Guilherme Menezes</span>
  </footer>
</div>
