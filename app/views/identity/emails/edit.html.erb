<div class="max-w-2xl mx-auto py-12 px-4">
  <div class="bg-white rounded-[2rem] shadow-sm border border-grey100 overflow-hidden">
    <div class="p-8 sm:p-12">
      <div class="flex flex-col gap-6">
        <div>
          <h1 class="text-2xl font-bold text-grey900">Configurações de E-mail</h1>
          <p class="text-grey600 mt-2">Gerencie o endereço de e-mail associado à sua conta GeoSafe.</p>
        </div>

        <% if !Current.user.verified? %>
          <div class="bg-primary50 rounded-2xl p-6 border border-primary100">
            <div class="flex gap-4">
              <div class="w-10 h-10 rounded-full bg-white flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-primary600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-bold text-primary900">Verifique seu e-mail</h3>
                <p class="text-primary700 text-sm mt-1">
                  Enviamos um e-mail de verificação para <strong><%= Current.user.email %></strong>.
                  Verifique sua caixa de entrada e siga as instruções.
                </p>
                <%= button_to identity_email_verification_path, class: "mt-4 text-sm font-bold text-primary600 hover:text-primary800 underline transition-colors" do %>
                  Reenviar e-mail de verificação
                <% end %>
              </div>
            </div>
          </div>
        <% end %>

        <%= form_with(url: identity_email_path, method: :patch, class: "space-y-8") do |form| %>
          <% if @user.errors.any? %>
            <div class="bg-red-50 border border-red-100 rounded-2xl p-4 text-red-700 text-sm">
              <ul class="list-disc list-inside">
                <% @user.errors.each do |error| %>
                  <li><%= error.full_message %></li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <div class="space-y-6">
            <div class="flex flex-col gap-2">
              <%= render(Input::InputComponent.new(
                name: :email,
                form: form,
                required: true,
                autofocus: true,
                label: "Novo E-mail:",
                placeholder: "exemplo@geosafe.com"
              )) %>
              <p class="text-[11px] text-grey500 pl-1">Utilize um e-mail que você tenha acesso frequente.</p>
            </div>

            <div class="flex flex-col gap-2">
              <%= render(Input::InputComponent.new(
                name: :password_challenge,
                form: form,
                required: true,
                autocomplete: "current-password",
                password: true,
                label: "Sua Senha Atual:",
                placeholder: "••••••••••••"
              )) %>
              <p class="text-[11px] text-grey500 pl-1">Por segurança, confirme sua senha para realizar esta alteração.</p>
            </div>
          </div>

          <div class="flex items-center justify-between pt-6 border-t border-grey100">
            <%= link_to root_path, class: "text-sm font-bold text-grey500 hover:text-grey700 transition-colors" do %>
              Cancelar
            <% end %>
            <%= render(Button::ButtonComponent.new(text: "Salvar Alterações", type: "submit", size: "lg")) %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
