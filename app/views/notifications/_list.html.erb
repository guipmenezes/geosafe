<% user ||= Current.user %>
<div class="w-80 sm:w-96 max-h-[450px] overflow-hidden flex flex-col">
  <div class="px-4 py-3 border-b border-grey100 flex items-center justify-between bg-grey50/50">
    <span class="text-sm font-bold text-grey900">Notificações</span>
    <% if user.notifications.unread.any? %>
      <%= button_to "Marcar todas como lidas", bulk_read_notifications_path, method: :post, class: "text-[10px] font-bold text-primary600 hover:text-primary700 underline" %>
    <% end %>
  </div>

  <div class="overflow-y-auto flex-1 custom-scrollbar">
    <% notifications = user.notifications.ordered.limit(5) %>
    <% if notifications.any? %>
      <div class="divide-y divide-grey50">
        <%= render partial: "notifications/notification_item", collection: notifications, as: :notification %>
      </div>
    <% else %>
      <div class="p-8 text-center">
        <div class="w-12 h-12 bg-grey50 rounded-full flex items-center justify-center mx-auto mb-3">
          <svg class="w-6 h-6 text-grey300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
        </div>
        <p class="text-xs text-grey500 font-medium">Nenhuma notificação por aqui.</p>
      </div>
    <% end %>
  </div>

  <%= link_to notifications_path, class: "px-4 py-3 border-t border-grey100 text-center text-xs font-bold text-primary600 hover:bg-primary50 transition-colors" do %>
    Ver todas as notificações
  <% end %>
</div>
