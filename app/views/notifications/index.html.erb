<div class="max-w-2xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-8">
    <h1 class="text-2xl font-bold text-grey900">Notificações</h1>
  </div>

  <div id="notifications-list" class="space-y-4">
    <% if @notifications.any? %>
      <%= render partial: "notifications/notification", collection: @notifications %>
    <% else %>
      <div class="text-center py-12 bg-white rounded-2xl shadow-sm border border-grey100">
        <div class="w-16 h-16 bg-grey50 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-grey400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
        </div>
        <p class="text-grey500 font-medium">Você ainda não possui notificações.</p>
        <p class="text-xs text-grey400 mt-1">Alertas de perigo em suas zonas de interesse aparecerão aqui.</p>
      </div>
    <% end %>
  </div>
</div>
