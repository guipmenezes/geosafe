<div id="<%= dom_id(notification) %>" class="group relative bg-white rounded-xl shadow-sm border border-grey100 p-4 transition-all hover:shadow-md <%= 'bg-blue-50/30' if notification.read_at.nil? %>">
  <div class="flex gap-4">
    <div class="flex-shrink-0">
      <div class="w-12 h-12 rounded-full bg-red-100 flex items-center justify-center text-red-600">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
    </div>

    <div class="flex-1 min-w-0">
      <div class="flex items-center justify-between mb-1">
        <span class="text-[10px] font-bold uppercase tracking-widest text-red-500 bg-red-50 px-2 py-0.5 rounded">Alerta de Perigo</span>
        <span class="text-[10px] font-medium text-grey400"><%= time_ago_in_words(notification.created_at) %> atrás</span>
      </div>

      <%= link_to alert_path(notification.alert), class: "block group-hover:text-primary600 transition-colors" do %>
        <h3 class="text-sm font-bold text-grey900 line-clamp-1"><%= notification.alert.title %></h3>
        <p class="text-xs text-grey600 mt-0.5 line-clamp-2"><%= notification.alert.description %></p>
      <% end %>

      <div class="flex items-center gap-1 mt-2 text-[10px] text-grey500">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        </svg>
        <%= notification.alert.location %>
      </div>
    </div>

    <% if notification.read_at.nil? %>
      <div class="flex-shrink-0 self-center">
        <%= button_to notification_path(notification), method: :patch, class: "p-2 text-grey400 hover:text-primary600 transition-colors", title: "Marcar como lida" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
