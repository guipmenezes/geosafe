<%= link_to home_path(alert_id: notification.alert.id),
            id: dom_id(notification, :toast),
            data: {
              controller: "notification-item flash",
              action: "click->notification-item#handleClick click->flash#close",
              notification_item_alert_id_value: notification.alert.id,
              notification_item_url_value: notification_path(notification)
            },
            class: "flex items-center gap-3 bg-red-600 hover:bg-red-700 text-white rounded-xl shadow-lg p-4 cursor-pointer transition-all border border-red-500 animate-slide-in-right" do %>
  <div class="w-8 h-8 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
    <svg class="w-5 h-5 text-white animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
    </svg>
  </div>
  <div class="flex-1 min-w-0">
    <h4 class="text-sm font-bold">Alerta de Perigo Próximo!</h4>
    <p class="text-xs opacity-90 line-clamp-1"><%= notification.alert.title %></p>
  </div>
  <span class="text-white/80 hover:text-white flex-shrink-0">
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </span>
<% end %>
