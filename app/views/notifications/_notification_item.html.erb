<%= link_to home_path(alert_id: notification.alert.id),
            class: "block p-4 hover:bg-grey50 transition-colors #{'bg-blue-50/20' if notification.read_at.nil?}",
            data: {
              controller: "notification-item",
              action: "click->notification-item#handleClick",
              notification_item_alert_id_value: notification.alert.id,
              notification_item_url_value: notification_path(notification)
            } do %>
  <div class="flex gap-3">
    <div class="flex-shrink-0">
      <div class="w-8 h-8 rounded-full bg-red-100 flex items-center justify-center text-red-600">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
      </div>
    </div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center justify-between gap-2">
        <p class="text-[13px] font-bold text-grey900 line-clamp-1"><%= notification.alert.title %></p>
        <span class="text-[9px] font-medium text-grey400 whitespace-nowrap"><%= time_ago_in_words(notification.created_at) %></span>
      </div>
      <p class="text-[11px] text-grey600 line-clamp-2 mt-0.5"><%= notification.alert.description %></p>
      <div class="flex items-center gap-1 mt-1.5 text-[10px] text-grey500">
        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        </svg>
        <span class="truncate"><%= notification.alert.location %></span>
      </div>
    </div>
    <% if notification.read_at.nil? %>
      <div class="flex-shrink-0">
        <div class="w-2 h-2 rounded-full bg-primary500 mt-1.5"></div>
      </div>
    <% end %>
  </div>
<% end %>
