<%= turbo_stream_from "alerts" %>

<div data-controller="map bottom-sheet"
     data-map-alerts-value="<%= @alerts_json %>"
     data-map-current-user-id-value="<%= Current.user&.id %>"
     class="flex flex-col lg:flex-row lg:gap-6 w-full h-[calc(100vh-120px)] lg:h-[calc(100vh-160px)] overflow-hidden pb-2 lg:pb-0 relative">

  <%# Main Content Area: Map %>
  <div class="w-full lg:w-[65%] flex-1 h-full rounded-2xl lg:rounded-3xl overflow-hidden shadow-sm border border-gray-100 relative order-1 mb-16 lg:mb-0">

    <%# Lupa GeoSafe (Integrated Search) - Increased Z-Index %>
    <div class="absolute top-3 left-3 lg:top-4 lg:left-4 z-30 w-[calc(100%-1.5rem)] sm:w-80">
      <div class="relative group">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
          <svg class="h-5 w-5 text-gray-400 group-focus-within:text-primary600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
        </div>
        <input type="text"
               data-map-target="searchInput"
               placeholder="Buscar endereço no GeoSafe..."
               autocomplete="off"
               class="block w-full pl-10 pr-3 py-3 lg:py-2 border border-gray-200 rounded-2xl leading-5 bg-white shadow-lg focus:outline-none focus:ring-2 focus:ring-primary500 focus:border-primary500 text-base lg:text-sm transition-all">
      </div>
    </div>

    <%# Safety Score Indicator - Increased Z-Index and adjusted position %>
    <div data-map-target="safetyScore" class="absolute bottom-36 lg:bottom-6 left-3 lg:left-6 z-30 hidden max-w-[180px] sm:max-w-none">
      <div class="bg-white/95 backdrop-blur-sm p-3 lg:p-4 rounded-2xl shadow-xl border border-gray-100 flex flex-col gap-1 min-w-[160px] sm:min-w-[200px]">
        <div class="flex items-center justify-between">
          <span class="text-[10px] lg:text-xs font-bold uppercase tracking-wider text-gray-500">Clima de Segurança</span>
          <span data-map-target="scoreValue" class="text-xs lg:text-sm font-bold">Excelente</span>
        </div>
        <div class="h-1.5 lg:h-2 w-full bg-gray-100 rounded-full overflow-hidden">
          <div data-map-target="scoreBar" class="h-full bg-green-500 transition-all duration-1000" style="width: 100%"></div>
        </div>
        <p data-map-target="scoreDescription" class="text-[9px] lg:text-[10px] text-gray-600 mt-1">Nenhum alerta recente nesta região.</p>
      </div>
    </div>

    <%# Map Container - No longer absolute, acts as base %>
    <div data-map-target="container" class="w-full h-full z-10"></div>

    <%# Create Alert Button (Mobile Floating) %>
    <div class="lg:hidden absolute bottom-20 right-3 z-[150]">
      <%= render(Modal::ModalComponent.new(title: "Criar GeoAlerta")) do |component| %>
        <% component.with_trigger do %>
          <button class="w-12 h-12 sm:w-14 sm:h-14 bg-primary600 text-white rounded-full shadow-2xl flex items-center justify-center hover:bg-primary700 transition-transform active:scale-95">
            <svg class="w-7 h-7 sm:w-8 sm:h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
          </button>
        <% end %>
        <%= render 'alerts/form', alert: @alert %>
      <% end %>
    </div>
  </div>

  <%# Sidebar Area: Alerts Feed & Filters %>
  <div data-bottom-sheet-target="sheet"
       class="fixed inset-x-0 bottom-0 z-40 bg-white rounded-t-[2.5rem] shadow-[0_-10px_40px_-15px_rgba(0,0,0,0.3)] lg:relative lg:inset-auto lg:z-[40] lg:bg-transparent lg:shadow-none lg:rounded-none lg:w-[35%] flex flex-col h-[85vh] lg:h-full transition-transform lg:translate-y-0 order-2 overflow-visible">

    <%# Drag Handle (Mobile Only) %>
    <div class="lg:hidden flex justify-center p-4 cursor-grab active:cursor-grabbing"
         data-action="touchstart->bottom-sheet#touchStart touchmove->bottom-sheet#touchMove touchend->bottom-sheet#touchEnd">
      <div class="w-12 h-1.5 bg-gray-300 rounded-full"></div>
    </div>

    <div class="flex flex-col h-full px-4 lg:px-0 overflow-visible">
      <div class="flex flex-row items-center justify-between mb-4 lg:pr-2">
        <h2 class="text-xl font-bold text-gray-900 lg:hidden">Alertas Próximos</h2>

        <%= render(Dropdown::DropdownComponent.new(title: "Minhas Zonas")) do %>
          <div class="w-72 sm:w-80">
            <% if Current.user.addresses.any? %>
              <div class="max-h-96 overflow-y-auto">
                <% Current.user.addresses.order(created_at: :asc).each do |address| %>
                  <%= link_to home_path(lat: address.latitude, lng: address.longitude), class: "flex items-start gap-3 px-4 py-3 hover:bg-primary50 transition-colors group border-b border-gray-50 last:border-0" do %>
                    <div class="mt-1">
                      <svg class="w-4 h-4 text-primary500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                    </div>
                    <div class="flex flex-col min-w-0">
                      <span class="font-bold text-gray-900 text-sm truncate"><%= address.label %></span>
                      <span class="text-[11px] text-gray-500 leading-tight mt-0.5"><%= address.full_address %></span>
                    </div>
                  <% end %>
                <% end %>
              </div>
              <div class="border-t border-gray-100 mt-1"></div>
            <% end %>
            <%= link_to interest_zones_path, class: "flex items-center gap-3 px-4 py-3 text-sm text-primary600 font-bold hover:bg-primary50 transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
              Gerenciar Zonas
            <% end %>
          </div>
        <% end %>

        <div class="hidden lg:block">
          <%= render(Modal::ModalComponent.new(title: "Criar GeoAlerta")) do |component| %>
            <% component.with_trigger do %>
              <%= render Button::ButtonComponent.new(text: "Criar GeoAlerta") %>
            <% end %>
            <%= render 'alerts/form', alert: @alert %>
          <% end %>
        </div>
      </div>

      <%# Category Filter Buttons %>
      <div data-map-target="categoryFilter" class="flex gap-2 mb-4 flex-wrap">
        <button data-category="1" class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 border border-blue-200 hover:bg-blue-100 transition-all cursor-pointer">
          🔒 Segurança
        </button>
        <button data-category="2" class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-orange-50 text-orange-700 border border-orange-200 hover:bg-orange-100 transition-all cursor-pointer">
          🚗 Trânsito
        </button>
        <button data-category="3" class="flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold bg-purple-50 text-purple-700 border border-purple-200 hover:bg-purple-100 transition-all cursor-pointer">
          🏛️ Utilidade Pública
        </button>
      </div>

      <div id="alerts"
           data-controller="alert-details"
           data-map-target="alertList"
           class="flex flex-col gap-4 overflow-y-auto pr-2 pb-24 lg:pb-10 custom-scrollbar">
        <% @alerts.each do |alert| %>
          <%= render(AlertCard::AlertCardComponent.new(alert: alert)) %>
        <% end %>

        <%# Detailed Alert Modal (populated by alert-details controller) %>
        <div data-alert-details-target="modal">
          <%= render Modal::ModalComponent.new(title: "Detalhes") do %>
            <%# Single Alert View %>
            <div data-alert-details-target="singleView" class="flex flex-col gap-4">
              <button data-action="click->alert-details#backToList" data-alert-details-target="backButton" class="hidden flex items-center gap-2 text-sm text-primary600 hover:text-primary700 font-semibold mb-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Voltar para a lista
              </button>
              <div class="flex justify-between items-start">
                <div>
                  <span data-alert-details-target="name" class="text-[10px] font-bold uppercase tracking-widest text-grey500 px-2 py-0.5 bg-grey100 rounded-md"></span>
                  <h1 data-alert-details-target="title" class="text-2xl font-bold text-grey900 mt-2"></h1>
                </div>
                <span data-alert-details-target="type" class=""></span>
              </div>

              <div class="flex items-center gap-2 text-sm text-grey600">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                </svg>
                <span data-alert-details-target="location"></span>
              </div>

              <div class="bg-grey50 rounded-xl p-4">
                <h3 class="text-sm font-semibold text-grey700 mb-2">Descrição</h3>
                <p data-alert-details-target="description" class="text-grey600 text-sm whitespace-pre-wrap"></p>
              </div>

              <div class="flex items-center justify-between pt-4 border-t border-grey100">
                <div class="text-xs text-grey500 flex flex-wrap items-center gap-2">
                  <span>Criado em <span data-alert-details-target="date"></span></span>
                  <span class="text-grey300">•</span>
                  <span>Nível do Criador:</span>
                  <span data-alert-details-target="creatorLevel" class="px-1.5 py-0.5 rounded text-[9px] font-bold uppercase tracking-wider"></span>
                </div>
              </div>
            </div>

            <%# Multiple Alerts View %>
            <div data-alert-details-target="listView" class="hidden flex flex-col gap-4 max-h-[60vh] overflow-y-auto pr-2 custom-scrollbar">
              <%# List items will be injected here %>
            </div>

            <template data-alert-details-target="itemTemplate">
              <div class="p-4 border border-grey100 rounded-xl hover:bg-grey50 transition-colors cursor-pointer group">
                <div class="flex justify-between items-start mb-2">
                  <span class="js-name text-[10px] font-bold uppercase tracking-widest text-grey500 px-2 py-0.5 bg-grey100 rounded-md"></span>
                  <span class="js-type-badge px-2 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider"></span>
                </div>
                <h3 class="js-title text-base font-semibold text-grey900 group-hover:text-primary600 transition-colors"></h3>
                <p class="js-description text-xs text-grey600 mt-1 line-clamp-2"></p>
                <div class="flex items-center justify-between mt-3 pt-3 border-t border-grey50 text-[10px] text-grey500">
                  <div class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    <span class="js-location"></span>
                  </div>
                  <span class="js-date"></span>
                </div>
              </div>
            </template>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
